# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GOO_ENABLED=true

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Provider selection. Leave unset or set to demo for deterministic demonstration mode.
SEARCH_PROVIDER=demo
EXTRACTION_PROVIDER=demo
ANALYSIS_PROVIDER=demo
EMBEDDING_PROVIDER=demo
BRAVE_API_KEY=
TAVILY_API_KEY=
SERPER_API_KEY=
OPENAI_API_KEY=

# Live search controls
LIVE_SEARCH_ALLOWED=false
ANONYMOUS_LIVE_SEARCH_LIMIT=3

# Admin protection
ADMIN_API_TOKEN=
DEMO_ADMIN_ACCESS=false

# Disabled by default: experimental bridge only, not part of production NOT GPT.
ENABLE_GOO_TO_NOTGPT_HOOK=false

# Rate limits
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_SEARCHES=20
RATE_LIMIT_GOO_MATCHES=40
RATE_LIMIT_INTERESTS=10
